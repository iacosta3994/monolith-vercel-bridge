# =============================================================================
# MONOLITH VERCEL BRIDGE - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to git!
#
# Generate secure tokens:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# =============================================================================

# -----------------------------------------------------------------------------
# SERVER CONFIGURATION
# -----------------------------------------------------------------------------
# Port for local development (Vercel ignores this)
PORT=3000

# Environment mode: development, production, or test
NODE_ENV=development

# -----------------------------------------------------------------------------
# AUTHENTICATION
# -----------------------------------------------------------------------------
# Bearer token for API authentication (required)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# This token will be used in the Authorization header: "Bearer YOUR_TOKEN"
BEARER_TOKEN=your-secure-bearer-token-here

# API key for additional authentication (required)
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
API_KEY=your-api-key-here

# -----------------------------------------------------------------------------
# MONOLITH AGENT CONFIGURATION
# -----------------------------------------------------------------------------
# URL of your Atlas Monolith Agent (must be accessible via Tailscale)
# Examples:
#   - https://monolith-agent.your-tailnet.ts.net
#   - https://100.64.1.2:8080
#   - http://monolith.local:3000
MONOLITH_AGENT_URL=https://monolith-agent.example.com

# API key for authenticating with the Monolith Agent
# Get this from your Monolith Agent configuration
MONOLITH_API_KEY=your-monolith-api-key

# -----------------------------------------------------------------------------
# TAILSCALE CONFIGURATION
# -----------------------------------------------------------------------------
# Tailscale API key for managing your tailnet
# Get from: https://login.tailscale.com/admin/settings/keys
# Create an API key with appropriate permissions
TAILSCALE_API_KEY=tskey-api-xxxxxxxxxxxxx

# Your Tailscale tailnet name
# Format: username.ts.net or organization.github.ts.net
# Find in: https://login.tailscale.com/admin/dns
TAILSCALE_TAILNET=yourname.ts.net

# Optional: Tailscale auth key for device registration
# Only needed if you want to register new devices
# Get from: https://login.tailscale.com/admin/settings/keys
TAILSCALE_AUTH_KEY=tskey-auth-xxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# LOGGING CONFIGURATION
# -----------------------------------------------------------------------------
# Log level: error, warn, info, debug
# Use 'debug' for development, 'info' for production
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# CORS CONFIGURATION
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins for CORS
# Use '*' to allow all origins (not recommended for production)
# Examples:
#   - http://localhost:3000,https://yourdomain.com
#   - https://poke.app
#   - *
ALLOWED_ORIGINS=*

# =============================================================================
# EXAMPLE CONFIGURATIONS
# =============================================================================

# Development Example:
# --------------------
# NODE_ENV=development
# PORT=3000
# BEARER_TOKEN=dev-token-12345
# API_KEY=dev-key-67890
# MONOLITH_AGENT_URL=http://localhost:8080
# MONOLITH_API_KEY=dev-monolith-key
# TAILSCALE_API_KEY=tskey-api-dev123
# TAILSCALE_TAILNET=dev.ts.net
# LOG_LEVEL=debug
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Production Example:
# -------------------
# NODE_ENV=production
# BEARER_TOKEN=a3f8c9d2e1b4567890abcdef1234567890abcdef1234567890abcdef12345678
# API_KEY=1a2b3c4d5e6f7g8h9i0j1k2l3m4n5o6p
# MONOLITH_AGENT_URL=https://monolith.prod-tailnet.ts.net
# MONOLITH_API_KEY=prod-monolith-secure-key-xyz
# TAILSCALE_API_KEY=tskey-api-prod123456789
# TAILSCALE_TAILNET=company.github.ts.net
# LOG_LEVEL=info
# ALLOWED_ORIGINS=https://poke.app,https://mcp.yourdomain.com

# =============================================================================
# SECURITY NOTES
# =============================================================================
# 1. NEVER commit this file with real values to git
# 2. Use .env for local development only
# 3. Set environment variables directly in Vercel for production
# 4. Rotate tokens and keys regularly
# 5. Use different tokens for each environment (dev, staging, prod)
# 6. Keep token length at 32+ bytes for security
# 7. Store tokens securely (password manager, secrets vault)
#
# =============================================================================
