{
  "name": "monolith-vercel-bridge",
  "version": "1.0.0",
  "description": "Production-ready Vercel MCP server with SSE transport for Atlas Monolith Agent integration",
  "main": "api/index.ts",
  "type": "module",
  "scripts": {
    "dev": "vercel dev",
    "build": "tsc",
    "deploy": "vercel --prod",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "sse",
    "server-sent-events",
    "vercel",
    "monolith",
    "atlas",
    "tailscale",
    "bridge",
    "poke"
  ],
  "author": "Ian Acosta",
  "license": "MIT",
  "dependencies": {
    "@vercel/node": "^3.0.12",
    "axios": "^1.6.5",
    "dotenv": "^16.3.1",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.18.1",
    "@typescript-eslint/parser": "^6.18.1",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3",
    "vercel": "^33.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
