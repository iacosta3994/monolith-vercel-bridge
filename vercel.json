{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "api/index.ts",
      "methods": ["GET"]
    },
    {
      "src": "/mcp",
      "dest": "api/index.ts",
      "methods": ["GET"]
    },
    {
      "src": "/api/mcp",
      "dest": "api/index.ts",
      "methods": ["POST"]
    },
    {
      "src": "/health",
      "dest": "api/index.ts",
      "methods": ["GET"]
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "api/index.ts": {
      "maxDuration": 10
    }
  }
}
