{
  "version": 2,
  "builds": [
    {
      "src": "src/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/health",
      "dest": "src/index.ts",
      "methods": ["GET"]
    },
    {
      "src": "/api/mcp/(.*)",
      "dest": "src/index.ts",
      "methods": ["POST", "GET"]
    },
    {
      "src": "/api/monolith/(.*)",
      "dest": "src/index.ts",
      "methods": ["POST", "GET"]
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}